<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 배경 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0E0E0" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- 프로필 배경 -->
    <item android:gravity="center" android:top="-40dp">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" />
            <size android:width="160dp" android:height="40dp" />
        </shape>
    </item>

    <!-- 프로필 이미지 원형 -->
    <item android:gravity="center" android:top="-10dp">
        <shape android:shape="oval">
            <solid android:color="#9E9E9E" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>

    <!-- 이름 텍스트 영역 -->
    <item android:gravity="center" android:top="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#9E9E9E" />
            <size android:width="100dp" android:height="10dp" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- 설정 목록 1 -->
    <item android:gravity="center" android:top="70dp">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" />
            <size android:width="160dp" android:height="20dp" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- 설정 목록 2 -->
    <item android:gravity="center" android:top="100dp">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" />
            <size android:width="160dp" android:height="20dp" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- 설정 목록 3 -->
    <item android:gravity="center" android:top="130dp">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" />
            <size android:width="160dp" android:height="20dp" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- 텍스트 표시 대신 이미지 사용 -->
    <item android:bottom="40dp" android:gravity="bottom|center_horizontal">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" />
            <size android:width="120dp" android:height="24dp" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list> 